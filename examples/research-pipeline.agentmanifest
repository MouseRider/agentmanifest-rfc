# AgentManifest — Research Pipeline
# Known workflow shape: gather → analyze → synthesize → verify → output.
# LangGraph's graph-based harness maps to this directly.
# Human review gates the verify step before final output.

FROM langgraph:latest

MODEL claude-opus
ROLE research-pipeline

TOOLS web-search, pdf-reader, file-system, summarizer

GRAPH {
  gather → analyze → synthesize → verify → output
}
CHECKPOINT after=gather, after=synthesize
HUMAN_REVIEW at=verify

GUARDRAILS cite-sources, max-length=10000
AUTONOMY medium

DEPLOY on-demand
TRIGGER api-call, schedule
RESOURCES memory=2g, timeout=60m
